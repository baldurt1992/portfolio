# Build tipo GitHub Pages en local (opcional): prueba con el slug de tu repo, p. ej. /portfolio/
# En CI el workflow calcula esto; para usuario.github.io suele ser /
NUXT_APP_BASE_URL=/

# EmailJS (opcional). Si faltan, el formulario abre mailto con el mensaje rellenado.
# GitHub → Settings → Secrets and variables → Actions → Repository secrets
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NUXT_PUBLIC_EMAILJS_SERVICE_ID=
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=
