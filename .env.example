# Copia a `.env` en local. En GitHub Pages no existe `.env` en el host: los valores `NUXT_PUBLIC_*`
# deben llegar al job de build (workflow) como secrets / variables.

# --- SEO (inyectado en el bundle en build time) ---
# URL pública absoluta, sin barra final. En CI puede calcularse automáticamente (workflow) o
# fijarse en Repo → Settings → Secrets and variables → Actions → Variables como `NUXT_PUBLIC_SITE_URL`
# si usas dominio personalizado u otra URL canónica.
NUXT_PUBLIC_SITE_URL=

# --- EmailJS (formulario de contacto; siguen siendo necesarios en CI como secrets) ---
# Repo → Settings → Secrets and variables → Actions → Secrets
NUXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NUXT_PUBLIC_EMAILJS_SERVICE_ID=
NUXT_PUBLIC_EMAILJS_TEMPLATE_ID=
